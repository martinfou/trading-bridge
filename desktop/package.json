{
  "name": "trading-bridge-desktop",
  "version": "0.1.0",
  "description": "Desktop backtest runner for Trading Bridge",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "lightweight-charts": "^5.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vue-tsc": "^2.2.0"
  },
  "build": {
    "appId": "com.martinfou.trading-bridge-desktop",
    "productName": "Trading Bridge",
    "directories": {
      "output": "dist-electron"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Finance"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.finance"
    }
  }
}
