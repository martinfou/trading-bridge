{
  "accounts": [
    {
      "id": "default",
      "provider": "OANDA",
      "tokenEnv": "OANDA_API_TOKEN",
      "accountIdEnv": "OANDA_ACCOUNT_ID",
      "restUrlEnv": "OANDA_REST_URL",
      "defaultRestUrl": "https://api-fxpractice.oanda.com"
    },
    {
      "id": "ibkr-paper",
      "provider": "IBKR",
      "accountIdEnv": "IBKR_ACCOUNT_ID",
      "hostEnv": "IBKR_GATEWAY_HOST",
      "portEnv": "IBKR_GATEWAY_PORT",
      "clientIdEnv": "IBKR_CLIENT_ID",
      "defaultPortPaper": 7497,
      "defaultPortLive": 7496
    }
  ]
}
