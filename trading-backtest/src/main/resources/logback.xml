<configuration>
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>
    <!-- Only WARN+ for BacktestEngine (too chatty at DEBUG) -->
    <logger name="com.martinfou.trading.backtest.BacktestEngine" level="WARN"/>
    <root level="WARN">
        <appender-ref ref="STDERR"/>
    </root>
</configuration>
